{
  "system_name": "starrocks",
  "system_kind": "starrocks",
  "system_version": "4.0.6",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS333E386AC108EFE04",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS333E386AC108EFE04 with ext4 filesystem",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS333E386AC108EFE04 /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS333E386AC108EFE04 to /data",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo mkdir -p /data/starrocks && sudo chmod 1777 /data/starrocks",
        "success": true,
        "description": "Create starrocks data directory",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data/starrocks",
        "success": true,
        "description": "Set ownership of /data/starrocks to ubuntu:ubuntu",
        "category": "storage_setup",
        "node_info": "all_nodes_4"
      }
    ],
    "prerequisites": [
      {
        "command": "sudo apt-get update && sudo apt-get install -y openjdk-17-jdk curl wget mysql-client",
        "success": true,
        "description": "Install Java, MySQL client, and utilities",
        "category": "prerequisites",
        "node_info": "all_nodes_4"
      },
      {
        "command": "echo \"export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64\" | sudo tee -a /etc/profile.d/java.sh",
        "success": true,
        "description": "Set JAVA_HOME environment variable",
        "category": "prerequisites",
        "node_info": "all_nodes_4"
      }
    ],
    "setup": [
      {
        "command": "test -f /tmp/starrocks-4.0.6.tar.gz && echo exists",
        "success": true,
        "description": "Execute test command on remote system",
        "category": "setup",
        "node_info": "all_nodes_4"
      }
    ],
    "installation": [
      {
        "command": "sudo mkdir -p /opt/starrocks && sudo tar -xzf /tmp/starrocks-4.0.6.tar.gz -C /opt/starrocks --strip-components=1",
        "success": true,
        "description": "Extract StarRocks to installation directory",
        "category": "installation",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo chown -R $(whoami):$(whoami) /opt/starrocks",
        "success": true,
        "description": "Set StarRocks directory ownership",
        "category": "installation",
        "node_info": "all_nodes_4"
      }
    ],
    "configuration": [
      {
        "command": "sudo tee /opt/starrocks/fe/conf/fe.conf > /dev/null << 'EOF'\n# StarRocks FE Configuration\nLOG_DIR = /opt/starrocks/fe/log\nmeta_dir = /opt/starrocks/fe/meta\nhttp_port = 8030\nrpc_port = 9020\nquery_port = 9030\nedit_log_port = 9010\npriority_networks = <PRIVATE_IP>/24\n# Performance tuning\nqe_max_connection = 1024\n# Memory settings\nmetadata_memory_limit = 8G\n\nEOF",
        "success": true,
        "description": "Configure StarRocks FE",
        "category": "configuration",
        "node_info": "all_nodes_4"
      },
      {
        "command": "sudo tee /opt/starrocks/be/conf/be.conf > /dev/null << 'EOF'\n# StarRocks BE Configuration\nLOG_DIR = /opt/starrocks/be/log\nbe_port = 9060\nbe_http_port = 8040\nheartbeat_service_port = 9050\nbrpc_port = 8060\npriority_networks = <PRIVATE_IP>/24\nstorage_root_path = /data/starrocks\n# Performance tuning - aggressive memory use with spill fallback\nmem_limit = 90%\n# Parallel execution\nparallel_fragment_exec_instance_num = 16\n# Spill-to-disk for memory-intensive queries (safety net)\nspill_local_storage_dir = /data/starrocks/spill\nenable_spill = true\nspill_mode = auto\n\nEOF",
        "success": true,
        "description": "Configure StarRocks BE",
        "category": "configuration",
        "node_info": "all_nodes_4"
      }
    ],
    "service_management": [
      {
        "command": "export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 && cd /opt/starrocks/fe && ./bin/start_fe.sh --daemon",
        "success": true,
        "description": "Start StarRocks FE",
        "category": "service_management",
        "node_info": "all_nodes_4"
      },
      {
        "command": "export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 && cd /opt/starrocks/be && ./bin/start_be.sh --daemon",
        "success": true,
        "description": "Start StarRocks BE",
        "category": "service_management",
        "node_info": "all_nodes_4"
      },
      {
        "command": "export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 && cd /opt/starrocks/fe && ./bin/start_fe.sh --helper <PRIVATE_IP>:9010 --daemon",
        "success": true,
        "description": "Start FE on follower nodes to join cluster",
        "category": "service_management"
      },
      {
        "command": "export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 && cd /opt/starrocks/be && ./bin/start_be.sh --daemon",
        "success": true,
        "description": "Start BE on all cluster nodes",
        "category": "service_management"
      }
    ],
    "cluster_configuration": [
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD FOLLOWER '<PRIVATE_IP>:9010'\"",
        "success": true,
        "description": "Add FE follower node 1",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD FOLLOWER '<PRIVATE_IP>:9010'\"",
        "success": true,
        "description": "Add FE follower node 2",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD FOLLOWER '<PRIVATE_IP>:9010'\"",
        "success": true,
        "description": "Add FE follower node 3",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD BACKEND '<PRIVATE_IP>:9050'\"",
        "success": true,
        "description": "Register BE on node 0",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD BACKEND '<PRIVATE_IP>:9050'\"",
        "success": true,
        "description": "Register BE on node 1",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD BACKEND '<PRIVATE_IP>:9050'\"",
        "success": true,
        "description": "Register BE on node 2",
        "category": "cluster_configuration"
      },
      {
        "command": "mysql -h <PRIVATE_IP> -P 9030 -u root -e \"ALTER SYSTEM ADD BACKEND '<PRIVATE_IP>:9050'\"",
        "success": true,
        "description": "Register BE on node 3",
        "category": "cluster_configuration"
      }
    ]
  },
  "installation_notes": [

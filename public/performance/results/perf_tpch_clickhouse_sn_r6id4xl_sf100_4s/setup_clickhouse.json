{
  "system_name": "clickhouse",
  "system_kind": "clickhouse",
  "system_version": "26.1.3.52",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS43180E450D224A19F",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS43180E450D224A19F with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS43180E450D224A19F /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS43180E450D224A19F to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/clickhouse && sudo chmod 1777 /data/clickhouse",
        "success": true,
        "description": "Create clickhouse data directory",
        "category": "storage_setup"
      }
    ]
  },
  "installation_notes": [
    "Storage device /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS43180E450D224A19F mounted at /data",
    "clickhouse data directory: /data/clickhouse",
    "Installing ClickHouse using official APT repository",
    "ClickHouse configuration file created: /etc/clickhouse-server/config.d/benchmark.xml",
    "ClickHouse user profile configured with optimized settings",

    "  max_bytes_in_join: 20000000000"
  ],
  "config_parameters": {
    "node_count": 1,
    "use_additional_disk": true,
    "data_dir": "/data/clickhouse",
    "host": "$CLICKHOUSE_PUBLIC_IP",
    "port": 8123,
    "username": "default",

{
  "system_name": "trino",
  "system_kind": "trino",
  "system_version": "479",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS466FEF4B759BBAAB1",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS466FEF4B759BBAAB1 with ext4 filesystem",
        "category": "storage_setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS466FEF4B759BBAAB1 /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS466FEF4B759BBAAB1 to /data",
        "category": "storage_setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo mkdir -p /data/trino && sudo chmod 1777 /data/trino",
        "success": true,
        "description": "Create trino data directory",
        "category": "storage_setup",
        "node_info": "all_nodes_8"
      }
    ],
    "prerequisites": [
      {
        "command": "wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public | sudo gpg --dearmor -o /usr/share/keyrings/adoptium.gpg 2>/dev/null || true\necho \"deb [signed-by=/usr/share/keyrings/adoptium.gpg] https://packages.adoptium.net/artifactory/deb $(lsb_release -sc) main\" | sudo tee /etc/apt/sources.list.d/adoptium.list",
        "success": true,
        "description": "Add Eclipse Temurin (Adoptium) repository for Java 22",
        "category": "prerequisites",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo apt-get update && sudo apt-get install -y temurin-25-jdk",
        "success": true,
        "description": "Install Java 25 (required by Trino 479+)",
        "category": "prerequisites",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo apt-get install -y python-is-python3",
        "success": true,
        "description": "Install python symlink (required by Trino launcher)",
        "category": "prerequisites",
        "node_info": "all_nodes_8"
      }
    ],
    "installation": [
      {
        "command": "wget -q --tries=3 --retry-connrefused --waitretry=5 https://github.com/trinodb/trino/releases/download/479/trino-server-479.tar.gz -O /tmp/trino-server.tar.gz",
        "success": true,
        "description": "Download Trino server version 479",
        "category": "installation",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo tar -xzf /tmp/trino-server.tar.gz -C /opt/",
        "success": true,
        "description": "Extract Trino server to /opt",
        "category": "installation",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo ln -sf /opt/trino-server-479 /opt/trino-server",
        "success": true,
        "description": "Create symlink /opt/trino-server",
        "category": "installation",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo mkdir -p /var/trino/data /etc/trino /var/log/trino",
        "success": true,
        "description": "Create Trino directories",
        "category": "installation",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo ln -sf /etc/trino /opt/trino-server/etc",
        "success": true,
        "description": "Create etc symlink for Trino launcher",
        "category": "installation",
        "node_info": "all_nodes_8"
      }
    ],
    "user_setup": [
      {
        "command": "sudo useradd -r -s /bin/false trino || true",
        "success": true,
        "description": "Create Trino system user",
        "category": "user_setup",
        "node_info": "all_nodes_8"
      }
    ],
    "configuration": [
      {
        "command": "sudo tee /etc/trino/node.properties > /dev/null << 'EOF'\nnode.environment=production\nnode.id=3bbe8f3e-3776-4ff2-9385-4741d44d2716\nnode.data-dir=/var/trino/data\nEOF",
        "success": true,
        "description": "Configure Trino node properties",
        "category": "configuration",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo tee /etc/trino/jvm.config > /dev/null << 'EOF'\n-server\n-Xmx12G\n-Xms12G\n-XX:+UseG1GC\n-XX:G1HeapRegionSize=32M\n-XX:+ExplicitGCInvokesConcurrent\n-XX:+HeapDumpOnOutOfMemoryError\n-XX:+ExitOnOutOfMemoryError\n-XX:ReservedCodeCacheSize=512M\n-Djdk.attach.allowAttachSelf=true\n-Djdk.nio.maxCachedBufferSize=2000000\nEOF",
        "success": true,
        "description": "Configure JVM with 12G heap (80% of 15.3G total RAM)",
        "category": "configuration",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo tee /etc/trino/config.properties > /dev/null << 'EOF'\ncoordinator=true\nnode-scheduler.include-coordinator=true\nhttp-server.http.port=8080\ndiscovery.uri=http://<PRIVATE_IP>:8080\nquery.max-memory=72GB\nquery.max-memory-per-node=8GB\nEOF",
        "success": true,
        "description": "Configure Trino as coordinator",
        "category": "configuration",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo tee /etc/trino/catalog/hive.properties > /dev/null << 'EOF'\nconnector.name=hive\nhive.metastore=file\nhive.metastore.catalog.dir=local:///data/trino/hive-metastore\nhive.storage-format=PARQUET\nhive.compression-codec=SNAPPY\nfs.native-local.enabled=true\nlocal.location=/\nfs.native-s3.enabled=true\ns3.region=eu-west-1\nEOF",
        "success": true,
        "description": "Configure Hive catalog with file metastore at local:///data/trino/hive-metastore",
        "category": "configuration",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo tee /etc/systemd/system/trino.service > /dev/null << 'EOF'\n[Unit]\nDescription=Trino Server\nAfter=network.target\n\n[Service]\nType=forking\nUser=trino\nGroup=trino\nExecStart=/opt/trino-server/bin/launcher start\nExecStop=/opt/trino-server/bin/launcher stop\nRestart=on-failure\nRestartSec=10\n\n[Install]\nWantedBy=multi-user.target\nEOF",
        "success": true,
        "description": "Create Trino systemd service",
        "category": "configuration",
        "node_info": "all_nodes_8"
      }
    ],
    "setup": [
      {
        "command": "sudo mkdir -p /data/trino/hive-metastore",
        "success": true,
        "description": "Execute sudo command on remote system",
        "category": "setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo chown -R trino:trino /data/trino/hive-metastore",
        "success": true,
        "description": "Execute sudo command on remote system",
        "category": "setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo chmod -R 755 /data/trino/hive-metastore",
        "success": true,
        "description": "Execute sudo command on remote system",
        "category": "setup",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo mkdir -p /etc/trino/catalog",
        "success": true,
        "description": "Execute sudo command on remote system",
        "category": "setup",
        "node_info": "all_nodes_8"
      }
    ],
    "service_management": [
      {
        "command": "sudo systemctl daemon-reload",
        "success": true,
        "description": "Reload systemd daemon",
        "category": "service_management",
        "node_info": "all_nodes_8"
      },
      {
        "command": "sudo systemctl start trino && sudo systemctl enable trino",
        "success": true,
        "description": "Start and enable Trino service",
        "category": "service_management",
        "node_info": "all_nodes_8"
      }
    ]
  },

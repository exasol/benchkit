{
  "system_name": "clickhouse",
  "system_kind": "clickhouse",
  "system_version": "26.1.3.52",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS65E3AB031C42BA31D",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS65E3AB031C42BA31D with ext4 filesystem",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS65E3AB031C42BA31D /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS65E3AB031C42BA31D to /data",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo mkdir -p /data/clickhouse && sudo chmod 1777 /data/clickhouse",
        "success": true,
        "description": "Create clickhouse data directory",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo chown -R clickhouse:clickhouse /data/clickhouse",
        "success": true,
        "description": "Set ownership of /data/clickhouse to clickhouse:clickhouse",
        "category": "storage_setup",
        "node_info": "all_nodes_2"
      }
    ],
    "prerequisites": [
      {
        "command": "sudo apt-get update",
        "success": true,
        "description": "Update package lists",
        "category": "prerequisites",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo apt-get install -y apt-transport-https ca-certificates curl gnupg",
        "success": true,
        "description": "Install prerequisite packages for secure repository access",
        "category": "prerequisites",
        "node_info": "all_nodes_2"
      }
    ],
    "repository_setup": [
      {
        "command": "curl -fsSL 'https://packages.clickhouse.com/rpm/lts/repodata/repomd.xml.key' | sudo gpg --dearmor -o /usr/share/keyrings/clickhouse-keyring.gpg",
        "success": true,
        "description": "Add ClickHouse GPG key to system keyring",
        "category": "repository_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "ARCH=$(dpkg --print-architecture) && echo \"deb [signed-by=/usr/share/keyrings/clickhouse-keyring.gpg arch=${ARCH}] https://packages.clickhouse.com/deb stable main\" | sudo tee /etc/apt/sources.list.d/clickhouse.list",
        "success": true,
        "description": "Add ClickHouse official repository to APT sources",
        "category": "repository_setup",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo apt-get update",
        "success": true,
        "description": "Update package lists with ClickHouse repository",
        "category": "repository_setup",
        "node_info": "all_nodes_2"
      }
    ],
    "installation": [
      {
        "command": "DEBIAN_FRONTEND=noninteractive sudo -E apt-get install -y clickhouse-common-static=26.1.3.52 clickhouse-server=26.1.3.52 clickhouse-client=26.1.3.52",
        "success": true,
        "description": "Install ClickHouse server and client version 26.1.3.52",
        "category": "installation",
        "node_info": "all_nodes_2"
      }
    ],
    "configuration": [
      {
        "command": "sudo tee /etc/clickhouse-server/config.d/benchmark.xml > /dev/null << 'EOF'\n<clickhouse>\n    <listen_host>::</listen_host>\n    <path>/data/clickhouse</path>\n    <tmp_path>/data/clickhouse/tmp</tmp_path>\n    <max_server_memory_usage>53066920755</max_server_memory_usage>\n    <max_concurrent_queries>14</max_concurrent_queries>\n    <background_pool_size>16</background_pool_size>\n    <background_schedule_pool_size>8</background_schedule_pool_size>\n    <max_table_size_to_drop>50000000000</max_table_size_to_drop>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Create custom ClickHouse configuration file",
        "category": "configuration",
        "node_info": "all_nodes_2"
      }
    ],
    "user_configuration": [
      {
        "command": "sudo tee /etc/clickhouse-server/users.d/benchmark.xml > /dev/null << 'EOF'\n<clickhouse>\n    <users>\n        <default replace=\"true\">\n            <password_sha256_hex>2cca9d8714615f4132390a3db9296d39ec051b3faff87be7ea5f7fe0e2de14c9</password_sha256_hex>\n            <networks>\n                <ip>::/0</ip>\n            </networks>\n        </default>\n    </users>\n    <profiles>\n        <default>\n            <max_threads>8</max_threads>\n            <max_memory_usage>12000000000</max_memory_usage>\n            <max_bytes_before_external_sort>4000000000</max_bytes_before_external_sort>\n            <max_bytes_before_external_group_by>4000000000</max_bytes_before_external_group_by>\n            <join_use_nulls>1</join_use_nulls>\n            <allow_experimental_correlated_subqueries>1</allow_experimental_correlated_subqueries>\n            <optimize_read_in_order>1</optimize_read_in_order>\n            <max_insert_threads>8</max_insert_threads>\n            <distributed_product_mode>global</distributed_product_mode>\n        </default>\n    </profiles>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Configure ClickHouse user profile with password and query settings",
        "category": "user_configuration",
        "node_info": "all_nodes_2"
      }
    ],
    "service_management": [
      {
        "command": "sudo systemctl start clickhouse-server",
        "success": true,
        "description": "Start ClickHouse server service",
        "category": "service_management",
        "node_info": "all_nodes_2"
      },
      {
        "command": "sudo systemctl enable clickhouse-server",
        "success": true,
        "description": "Enable ClickHouse server to start on boot",
        "category": "service_management",
        "node_info": "all_nodes_2"
      }
    ],
    "cluster_configuration": [
      {
        "command": "sudo tee /etc/clickhouse-server/config.d/remote_servers.xml > /dev/null << 'EOF'\n<clickhouse>\n    <remote_servers>\n        <benchmark_cluster>\n        <shard>\n            <replica>\n                <host><PRIVATE_IP></host>\n                <port>9000</port>\n                <user>default</user>\n                <password><DATABASE_PASSWORD></password>\n            </replica>\n        </shard>\n        <shard>\n            <replica>\n                <host><PRIVATE_IP></host>\n                <port>9000</port>\n                <user>default</user>\n                <password><DATABASE_PASSWORD></password>\n            </replica>\n        </shard>\n        </benchmark_cluster>\n    </remote_servers>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Create cluster configuration (remote_servers.xml) on all nodes",
        "category": "cluster_configuration"
      },
      {
        "command": "sudo tee /etc/clickhouse-server/config.d/macros.xml > /dev/null << 'EOF'\n<clickhouse>\n    <macros>\n        <cluster>benchmark_cluster</cluster>\n        <shard>1</shard>\n        <replica>node1</replica>\n    </macros>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Create node-specific macros (example for node 0)",
        "category": "cluster_configuration"
      },
      {
        "command": "sudo systemctl restart clickhouse-server",
        "success": true,
        "description": "Restart ClickHouse on all nodes (parallel for Keeper quorum)",
        "category": "cluster_configuration"
      }
    ],
    "keeper_configuration": [
      {
        "command": "sudo tee /etc/clickhouse-server/config.d/keeper.xml > /dev/null << 'EOF'\n<clickhouse>\n    <keeper_server>\n        <tcp_port>9181</tcp_port>\n        <server_id>1</server_id>\n        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>\n        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>\n        <coordination_settings>\n            <operation_timeout_ms>10000</operation_timeout_ms>\n            <session_timeout_ms>30000</session_timeout_ms>\n            <raft_logs_level>warning</raft_logs_level>\n        </coordination_settings>\n        <raft_configuration>\n            <server>\n                <id>1</id>\n                <hostname><PRIVATE_IP></hostname>\n                <port>9234</port>\n            </server>\n            <server>\n                <id>2</id>\n                <hostname><PRIVATE_IP></hostname>\n                <port>9234</port>\n            </server>\n        </raft_configuration>\n    </keeper_server>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Create ClickHouse Keeper server config (example for node 0)",
        "category": "keeper_configuration"
      },
      {
        "command": "sudo tee /etc/clickhouse-server/config.d/use_keeper.xml > /dev/null << 'EOF'\n<clickhouse>\n    <zookeeper>\n        <node>\n            <host><PRIVATE_IP></host>\n            <port>9181</port>\n        </node>\n        <node>\n            <host><PRIVATE_IP></host>\n            <port>9181</port>\n        </node>\n    </zookeeper>\n    <distributed_ddl>\n        <path>/clickhouse/task_queue/ddl</path>\n    </distributed_ddl>\n</clickhouse>\nEOF",
        "success": true,
        "description": "Create ZooKeeper client config pointing to Keeper cluster",
        "category": "keeper_configuration"
      }
    ]
  },

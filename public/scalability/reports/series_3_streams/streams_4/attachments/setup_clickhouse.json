{
  "system_name": "clickhouse",
  "system_kind": "clickhouse",
  "system_version": "25.10.2.65",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10C13CC961BA7B5A7",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10C13CC961BA7B5A7 with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10C13CC961BA7B5A7 /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10C13CC961BA7B5A7 to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/clickhouse",
        "success": true,
        "description": "Create clickhouse data directory",
        "category": "storage_setup"
      }
    ]
  },
  "installation_notes": [

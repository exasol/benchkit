{
  "system_name": "trino",
  "system_kind": "trino",
  "system_version": "479",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10AF1FBC56A5D0DE7",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10AF1FBC56A5D0DE7 with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10AF1FBC56A5D0DE7 /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10AF1FBC56A5D0DE7 to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/trino",
        "success": true,
        "description": "Create trino data directory",
        "category": "storage_setup"
      }
    ],
    "installation": [
      {
        "command": "sudo mkdir -p /var/trino/data /etc/trino /var/log/trino",
        "success": true,
        "description": "Create Trino directories",
        "category": "installation"
      }
    ]
  },
  "installation_notes": [
    "Storage device /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS10AF1FBC56A5D0DE7 mounted at /data",
    "trino data directory: /data/trino",
    "Installing Trino single-node (coordinator only)",
    "Waiting for Trino to be ready for connections...",
    "\u2713 Trino is ready and accepting connections"
  ],
  "config_parameters": {
    "node_count": 1,
    "use_additional_disk": true,
    "host": "<PUBLIC_IP>",
    "port": 8080,
    "username": "admin",
    "catalog": "hive",
    "schema": "tpch_views",
    "extra": {
      "query_max_memory": "18GB",
      "query_max_memory_per_node": "18GB"
    }
  },
  "data_directory": "/data/trino"
}
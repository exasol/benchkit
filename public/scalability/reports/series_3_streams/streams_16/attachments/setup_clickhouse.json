{
  "system_name": "clickhouse",
  "system_kind": "clickhouse",
  "system_version": "26.1.3.52",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mdadm --stop /dev/md0 2>/dev/null || true",
        "success": true,
        "description": "Stop existing RAID array at /dev/md0 if present",
        "category": "storage_setup"
      },
      {
        "command": "sudo wipefs -a /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS4325D27F2918D9E44 2>/dev/null || true",
        "success": true,
        "description": "Clear filesystem signatures on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS4325D27F2918D9E44",
        "category": "storage_setup"
      },
      {
        "command": "sudo wipefs -a /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS64C4E764A41E3B5CE 2>/dev/null || true",
        "success": true,
        "description": "Clear filesystem signatures on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS64C4E764A41E3B5CE",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --zero-superblock /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS4325D27F2918D9E44 2>/dev/null || true",
        "success": true,
        "description": "Clear RAID superblock on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS4325D27F2918D9E44",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --zero-superblock /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS64C4E764A41E3B5CE 2>/dev/null || true",
        "success": true,
        "description": "Clear RAID superblock on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS64C4E764A41E3B5CE",
        "category": "storage_setup"
      },
      {
        "command": "yes | sudo mdadm --create /dev/md0 --level=0 --raid-devices=2 /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS4325D27F2918D9E44 /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS64C4E764A41E3B5CE",
        "success": true,
        "description": "Create RAID0 array from 2 devices",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --wait /dev/md0 2>/dev/null || true",
        "success": true,
        "description": "Wait for RAID array /dev/md0 to be ready",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /etc/mdadm",
        "success": true,
        "description": "Create mdadm configuration directory",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --detail --scan | sudo tee -a /etc/mdadm/mdadm.conf",
        "success": true,
        "description": "Save RAID configuration",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkfs.ext4 -F /dev/md0",
        "success": true,
        "description": "Format /dev/md0 with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/md0 /data",
        "success": true,
        "description": "Mount /dev/md0 to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/clickhouse && sudo chmod 1777 /data/clickhouse",
        "success": true,
        "description": "Create clickhouse data directory",
        "category": "storage_setup"
      }
    ]
  },
  "installation_notes": [
    "RAID0 array created: /dev/md0 from 2 devices",
    "Storage device /dev/md0 mounted at /data",
    "clickhouse data directory: /data/clickhouse",
    "Installing ClickHouse using official APT repository",
    "ClickHouse configuration file created: /etc/clickhouse-server/config.d/benchmark.xml",
    "ClickHouse user profile configured with optimized settings",
    "Waiting for ClickHouse server to be ready for connections...",
    "ClickHouse server is ready and accepting connections",
    "ClickHouse configuration applied:",
    "  Hardware-detected settings (CPU cores: 64, RAM: 495.8GB)",
    "  max_threads: 64",
    "  max_memory_usage: 24.0GB",
    "  max_bytes_before_external_sort: 8.0GB",
    "  max_bytes_before_external_group_by: 8.0GB",
    "  max_server_memory_usage: 425.9GB",
    "  max_concurrent_queries: 64",
    "  background_pool_size: 64",
    "  background_schedule_pool_size: 64",
    "  max_table_size_to_drop: 50.0GB",
    "  memory_limit: 384g",
    "  join_algorithm: grace_hash",
    "  max_bytes_in_join: 16000000000"
  ],
  "config_parameters": {
    "node_count": 1,
    "use_additional_disk": true,
    "data_dir": "/data/clickhouse",
    "host": "$CLICKHOUSE_PUBLIC_IP",
    "port": 8123,
    "username": "default",
    "password": "<DATABASE_PASSWORD>",
    "extra": {
      "memory_limit": "384g",
      "max_threads": "64",
      "max_memory_usage": "24000000000",
      "max_bytes_before_external_group_by": "8000000000",
      "max_bytes_before_external_sort": "8000000000",
      "join_algorithm": "grace_hash",
      "max_bytes_in_join": "16000000000"
    }
  },
  "data_directory": "/data/clickhouse"
}
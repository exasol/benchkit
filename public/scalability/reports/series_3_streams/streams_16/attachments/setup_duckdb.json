{
  "system_name": "duckdb",
  "system_kind": "duckdb",
  "system_version": "1.4.4",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mdadm --stop /dev/md0 2>/dev/null || true",
        "success": true,
        "description": "Stop existing RAID array at /dev/md0 if present",
        "category": "storage_setup"
      },
      {
        "command": "sudo wipefs -a /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS1BDDF0E3383FD18C7 2>/dev/null || true",
        "success": true,
        "description": "Clear filesystem signatures on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS1BDDF0E3383FD18C7",
        "category": "storage_setup"
      },
      {
        "command": "sudo wipefs -a /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS22669018B9009737C 2>/dev/null || true",
        "success": true,
        "description": "Clear filesystem signatures on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS22669018B9009737C",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --zero-superblock /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS1BDDF0E3383FD18C7 2>/dev/null || true",
        "success": true,
        "description": "Clear RAID superblock on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS1BDDF0E3383FD18C7",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --zero-superblock /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS22669018B9009737C 2>/dev/null || true",
        "success": true,
        "description": "Clear RAID superblock on /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS22669018B9009737C",
        "category": "storage_setup"
      },
      {
        "command": "yes | sudo mdadm --create /dev/md0 --level=0 --raid-devices=2 /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS1BDDF0E3383FD18C7 /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS22669018B9009737C",
        "success": true,
        "description": "Create RAID0 array from 2 devices",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --wait /dev/md0 2>/dev/null || true",
        "success": true,
        "description": "Wait for RAID array /dev/md0 to be ready",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /etc/mdadm",
        "success": true,
        "description": "Create mdadm configuration directory",
        "category": "storage_setup"
      },
      {
        "command": "sudo mdadm --detail --scan | sudo tee -a /etc/mdadm/mdadm.conf",
        "success": true,
        "description": "Save RAID configuration",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkfs.ext4 -F /dev/md0",
        "success": true,
        "description": "Format /dev/md0 with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/md0 /data",
        "success": true,
        "description": "Mount /dev/md0 to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/duckdb",
        "success": true,
        "description": "Create duckdb data directory",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data/duckdb",
        "success": true,
        "description": "Set ownership of /data/duckdb to ubuntu:ubuntu",
        "category": "storage_setup"
      }
    ],
    "preparation": [
      {
        "command": "sudo mkdir -p /data/duckdb && sudo chown ubuntu:ubuntu /data/duckdb",
        "success": true,
        "description": "Create DuckDB data directory: /data/duckdb",
        "category": "preparation"
      }
    ]
  },
  "installation_notes": [
    "RAID0 array created: /dev/md0 from 2 devices",
    "Storage device /dev/md0 mounted at /data",
    "duckdb data directory: /data/duckdb",
    "Setting up DuckDB embedded database",
    "DuckDB 1.4.4 installed",
    "Database path: /data/duckdb/benchmark.duckdb"
  ],
  "config_parameters": {
    "use_additional_disk": true,
    "data_dir": "/data/duckdb",
    "database_path": "/data/duckdb/benchmark.duckdb",
    "extra": {
      "memory_limit": "384GB",
      "threads": 64
    }
  },
  "data_directory": "/data/duckdb"
}
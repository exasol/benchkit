{
  "system_name": "starrocks",
  "system_kind": "starrocks",
  "system_version": "4.0.4",
  "commands": {
    "storage_setup": [
      {
        "command": "sudo mkfs.ext4 -F /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS23DC35E40AC69FA72",
        "success": true,
        "description": "Format /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS23DC35E40AC69FA72 with ext4 filesystem",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data",
        "success": true,
        "description": "Create mount point /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS23DC35E40AC69FA72 /data",
        "success": true,
        "description": "Mount /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS23DC35E40AC69FA72 to /data",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data",
        "success": true,
        "description": "Set ownership of /data to ubuntu:ubuntu",
        "category": "storage_setup"
      },
      {
        "command": "sudo mkdir -p /data/starrocks",
        "success": true,
        "description": "Create starrocks data directory",
        "category": "storage_setup"
      },
      {
        "command": "sudo chown -R ubuntu:ubuntu /data/starrocks",
        "success": true,
        "description": "Set ownership of /data/starrocks to ubuntu:ubuntu",
        "category": "storage_setup"
      }
    ]
  },
  "installation_notes": [
    "Storage device /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage_AWS23DC35E40AC69FA72 mounted at /data",
    "starrocks data directory: /data/starrocks",
    "Installing StarRocks using official tarball"
  ],
  "config_parameters": {
    "node_count": 1,
    "use_additional_disk": true,
    "host": "<PUBLIC_IP>",
    "port": 9030,
    "username": "root",
    "password": "",
    "extra": {
      "bucket_count": 4,
      "replication_num": 1
    }
  },
  "data_directory": "/data/starrocks"
}
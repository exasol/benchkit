    "prerequisites": [
      {
        "command": "sudo apt-get update && sudo apt-get install -y openjdk-17-jdk curl wget mysql-client",
        "success": true,
        "description": "Install Java, MySQL client, and utilities",
        "category": "prerequisites"
      },
      {
        "command": "echo \"export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64\" | sudo tee -a /etc/profile.d/java.sh",
        "success": true,
        "description": "Set JAVA_HOME environment variable",
        "category": "prerequisites"
      }
    ],
    "installation": [
      {
        "command": "wget -q -O /tmp/starrocks-4.0.4.tar.gz https://releases.starrocks.io/starrocks/StarRocks-4.0.4-ubuntu-amd64.tar.gz",
        "success": true,
        "description": "Download StarRocks 4.0.4",
        "category": "installation"
      },
      {
        "command": "sudo mkdir -p /opt/starrocks && sudo tar -xzf /tmp/starrocks-4.0.4.tar.gz -C /opt/starrocks --strip-components=1",
        "success": true,
        "description": "Extract StarRocks to installation directory",
        "category": "installation"
      },
      {
        "command": "sudo chown -R $(whoami):$(whoami) /opt/starrocks",
        "success": true,
        "description": "Set StarRocks directory ownership",
        "category": "installation"
      }
    ],
    "configuration": [
      {
        "command": "sudo tee /opt/starrocks/fe/conf/fe.conf > /dev/null << 'EOF'\n# StarRocks FE Configuration\nLOG_DIR = /opt/starrocks/fe/log\nmeta_dir = /opt/starrocks/fe/meta\nhttp_port = 8030\nrpc_port = 9020\nquery_port = 9030\nedit_log_port = 9010\npriority_networks = <PRIVATE_IP>/24\n# Performance tuning\nqe_max_connection = 1024\n# Memory settings\nmetadata_memory_limit = 8G\n\nEOF",
        "success": true,
        "description": "Configure StarRocks FE",
        "category": "configuration"
      },
      {
        "command": "sudo tee /opt/starrocks/be/conf/be.conf > /dev/null << 'EOF'\n# StarRocks BE Configuration\nLOG_DIR = /opt/starrocks/be/log\nbe_port = 9060\nbe_http_port = 8040\nheartbeat_service_port = 9050\nbrpc_port = 8060\npriority_networks = <PRIVATE_IP>/24\nstorage_root_path = /data/starrocks\n# Performance tuning - aggressive memory use with spill fallback\nmem_limit = 90%\n# Parallel execution\nparallel_fragment_exec_instance_num = 16\n# Spill-to-disk for memory-intensive queries (safety net)\nspill_local_storage_dir = /data/starrocks/spill\nenable_spill = true\nspill_mode = auto\n\nEOF",
        "success": true,
        "description": "Configure StarRocks BE",
        "category": "configuration"
      }
    ],
    "service_management": [
      {
        "command": "cd /opt/starrocks/fe && ./bin/start_fe.sh --daemon",
        "success": true,
        "description": "Start StarRocks FE",
        "category": "service_management"
      },
      {
        "command": "cd /opt/starrocks/be && ./bin/start_be.sh --daemon",
        "success": true,
        "description": "Start StarRocks BE",
        "category": "service_management"
      }
    ]
  },

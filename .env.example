# Example .env file for database benchmark framework
# Copy this to .env and customize for your environment

# AWS Configuration
# AWS_PROFILE=default-mfa
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# GCP Configuration
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json

# Azure Configuration
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# STACKIT Configuration
# STACKIT_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# STACKIT_IMAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Authentication: Key Flow (recommended) or Token Flow
# Key Flow:
# STACKIT_SERVICE_ACCOUNT_KEY_PATH=/path/to/sa_key.json
# STACKIT_PRIVATE_KEY_PATH=/path/to/private_key.pem
# Token Flow (less secure):
# STACKIT_SERVICE_ACCOUNT_TOKEN=your-service-account-token

# Database connection overrides (if needed for local testing)
# EXASOL_HOST=localhost
# EXASOL_PORT=8563
# EXASOL_USERNAME=sys
# EXASOL_PASSWORD=exasol
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=clickhouse123

# Benchmark configuration overrides
# BENCHMARK_PRESERVE_SYSTEMS=true
# BENCHMARK_DEBUG_MODE=true